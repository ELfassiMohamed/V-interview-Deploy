# Gemini API Key for AI Interview Processing
GEMINI_API_KEY=your_gemini_api_key_here

# Django Secret Key (Run 'python manage.py shell' and 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=your_secret_key_here

# Database Configuration (PostgreSQL)
DB_NAME=vinterview_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# Debug Mode (set to False in production)
DEBUG=True
