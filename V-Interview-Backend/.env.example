# API Key for AI Interview Processing
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (for DeepSeek and other models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Primary AI Model (options: gemini, deepseek)
PRIMARY_AI_MODEL=gemini

# Django Secret Key (Generated for local development)
SECRET_KEY=your_secret_key_here

# Database Configuration (PostgreSQL connection URL)
DATABASE_URL=postgres://postgres:your_password_here@localhost:5432/vinterview_db

# Debug Mode (set to False in production)
DEBUG=True
